# JIRA Integration — STLC MCP Project
# Copy this file to .env and fill in real values.
# The .env file is gitignored — never commit credentials.

JIRA_URL=https://your-site.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-atlassian-api-token
JIRA_PROJECT_KEY=KAN
JIRA_CLOUD_ID=your-cloud-uuid

# VWO credentials — required for TC_LOGIN_001 and TC_LOGIN_005 (tests self-skip when absent)
# VWO_TEST_EMAIL=your-vwo-email@example.com
# VWO_TEST_PASSWORD=your-vwo-password
